# LOOMWIRE is built for bring-your-own-key usage.
# Server-side keys are optional for self-hosted demos; the UI can also send
# a user-provided key per request without storing it.

NEXT_PUBLIC_SITE_URL=https://your-netlify-site.netlify.app

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=

# Optional. The Shopify connector uses each user's own store token in the UI.
SHOPIFY_ADMIN_API_VERSION=2026-04

# Netlify Blobs context is injected automatically on Netlify.
# Local Next dev falls back to .loomwire-storage/ for server Vault API tests.
