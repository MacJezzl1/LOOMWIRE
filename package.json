{
  "name": "loomwire",
  "version": "0.1.0",
  "private": true,
  "description": "LOOMWIRE turns raw ideas into protected, visual, sellable cultural brand systems.",
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "smoke": "node scripts/smoke.mjs",
    "responsive": "node scripts/responsive.mjs",
    "check": "npm run typecheck && npm run build && npm run smoke && npm run responsive",
    "netlify:dev": "npx netlify dev",
    "netlify:deploy": "npx netlify deploy --build",
    "netlify:deploy:prod": "npx netlify deploy --build --prod"
  },
  "dependencies": {
    "@netlify/blobs": "^10.1.0",
    "framer-motion": "^12.23.0",
    "lucide-react": "^0.468.0",
    "next": "^15.3.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.178.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.185.0",
    "autoprefixer": "^10.4.20",
    "playwright": "^1.61.1",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
